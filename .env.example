# bakom-mcp environment variables (template)
#
# bakom-mcp benoetigt aktuell keine Secrets — alle Datenquellen sind
# Open Government Data ohne Authentifizierung.
#
# Diese Datei dient als Platzhalter fuer kuenftige optionale Konfiguration.
# Niemals echte Secrets in dieser Datei committen — sie ist im Repo.
# Lokale Werte gehoeren in eine `.env`-Datei (via .gitignore ausgeschlossen).

# HTTP-Transport: Bind-Host (Default: 127.0.0.1).
# Fuer 0.0.0.0 explizit setzen — Warnung wird auf stderr ausgegeben.
# BAKOM_MCP_HOST=127.0.0.1

# HTTP-Transport: Port (Default: 8050).
# BAKOM_MCP_PORT=8050

# HTTP-Transport: Erlaubte CORS-Origins als Komma-Liste.
# Default: leer (CORS deaktiviert — sicherster Default fuer Server-zu-Server).
# Fuer Browser-Clients explizit setzen, niemals "*" mit Credentials.
# BAKOM_MCP_CORS_ORIGINS=https://app.example.com,https://app2.example.com

# Beispiel fuer kuenftige Premium-API-Schluessel (nicht aktiv):
# OPENDATA_SWISS_API_KEY=your-key-if-rate-limited
